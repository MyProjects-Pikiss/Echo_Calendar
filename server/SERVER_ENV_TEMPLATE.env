# Echo Calendar AI env template
# Copy this file to an external path (outside this project),
# then set keys for the features you use:
# - OPENAI_API_KEY for AI endpoints
# - KOREA_HOLIDAY_API_KEY for /holidays endpoint

# Required: OpenAI API key
OPENAI_API_KEY=sk-xxxx

# Optional: model name (default: gpt-5-nano)
OPENAI_MODEL=gpt-5-nano

# Optional: request timeout in seconds (default: 40)
LLM_TIMEOUT_SECONDS=40

# Optional: retry count when LLM call fails (default: 0)
LLM_MAX_RETRIES=0

# Optional: total deadline for one LLM request cycle including retries (default: 60)
LLM_DEADLINE_SECONDS=60

# Optional: max output tokens per LLM response (default: 256)
LLM_MAX_OUTPUT_TOKENS=256

# Optional: backend rate limit per minute (default: 60)
RATE_LIMIT_PER_MINUTE=60

# Optional: block common bot probe paths (default: true)
BLOCK_PROBE_REQUESTS=true

# Optional: allow public signup via /auth/signup (default: false)
ALLOW_SIGNUP=false

# Local fallback is disabled by code policy.
# Keep this false.
ENABLE_LOCAL_FALLBACK=false

# Required for holiday sync API (/holidays): data.go.kr service key
# - Use "Decoding" key value if possible.
# - This key is used by backend to fetch Korean public holidays/special days.
KOREA_HOLIDAY_API_KEY=

# Optional: data.go.kr endpoint
KOREA_HOLIDAY_API_BASE_URL=https://apis.data.go.kr/B090041/openapi/service/SpcdeInfoService/getRestDeInfo

# Optional: timeout seconds for each upstream request
KOREA_HOLIDAY_API_TIMEOUT_SECONDS=8

# Optional: parallel month-request count (higher = faster but more load)
KOREA_HOLIDAY_API_MAX_CONCURRENCY=6

# Optional: server-side holiday cache DB path (default: data/holiday_cache.db)
HOLIDAY_DB_PATH=data/holiday_cache.db

# Optional: usage analytics DB path (default: data/usage.db)
USAGE_DB_PATH=data/usage.db

# Optional: only this username can read /usage/overview and /usage/user-detail.
# If empty, any logged-in user can read usage APIs.
USAGE_DASHBOARD_OWNER_USERNAME=

# Optional: query key required to open /usage/dashboard page.
# Example: /usage/dashboard?key=your-secret-key
USAGE_DASHBOARD_ACCESS_KEY=

# Optional: bootstrap admin account on server startup.
# If both are set, this account is migrated/enforced as the only admin.
# (Other existing admin accounts are removed.)
USAGE_ADMIN_USERNAME=
USAGE_ADMIN_PASSWORD=

# Optional: enable startup/daily sync loop in server process (default: true)
HOLIDAY_SYNC_ENABLED=true

# Optional: initial full sync range start date (default: 1970-01-01)
HOLIDAY_BOOTSTRAP_START_DATE=1970-01-01

# Optional: initial full sync range end offset years from today (default: 5)
HOLIDAY_BOOTSTRAP_FORWARD_YEARS=5

# Optional: daily sync window around today in years (default: 1)
HOLIDAY_DAILY_WINDOW_YEARS=1

# Optional: app update check values for /app/version endpoint
# - 앱의 versionCode/versionName에 맞춰 업데이트하세요.
APP_LATEST_VERSION_CODE=3
APP_LATEST_VERSION_NAME=0.9.1
APP_MIN_SUPPORTED_VERSION_CODE=3

# Optional: local APK deploy settings served by backend static route (/downloads/*)
# - Relative path is resolved from "server" folder.
APP_DOWNLOADS_DIR=downloads
APP_APK_FILENAME=echo_calendar.apk

# Optional: direct APK download URL shown to legacy clients
# Example: https://echo-calendar.win/downloads/echo_calendar.apk
# - If empty, backend auto-generates URL from APP_DOWNLOADS_DIR/APP_APK_FILENAME.
APP_APK_DOWNLOAD_URL=https://echo-calendar.win/downloads/echo_calendar.apk
