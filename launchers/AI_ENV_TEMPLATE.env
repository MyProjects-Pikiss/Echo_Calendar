# Echo Calendar AI env template
# Copy this file to an external path (outside this project),
# then set at least OPENAI_API_KEY.

# Required: OpenAI API key
OPENAI_API_KEY=sk-xxxx

# Optional: model name (default: gpt-5-mini)
OPENAI_MODEL=gpt-5-mini

# Optional: request timeout in seconds (default: 12)
LLM_TIMEOUT_SECONDS=12

# Optional: retry count when LLM call fails (default: 1)
LLM_MAX_RETRIES=1

# Optional: backend rate limit per minute (default: 60)
RATE_LIMIT_PER_MINUTE=60

# Optional: use local parser fallback when remote call fails (default: true)
ENABLE_LOCAL_FALLBACK=true
